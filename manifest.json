{
  "name": "Coverly – Insurance Vault",
  "short_name": "Coverly",
  "version": "1.1.0-beta",
  "description": "Privacy-first, offline insurance vault for emergencies",
  "id": "/Coverly/",
  "start_url": "/Coverly/",
  "scope": "/Coverly/",
  "lang": "en-GB",
  "dir": "ltr",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#0a0f1e",
  "theme_color": "#0a0f1e",
  "categories": ["finance", "utilities"],
  "iarc_rating_id": "",
  "icons": [
    {
      "src": "icon-192-coverly.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-192-coverly.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icon-512-coverly.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512-coverly.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "file_handlers": [
    {
      "action": "/Coverly/",
      "accept": {
        "application/octet-stream": [".coverly"],
        "application/coverly": [".coverly"]
      },
      "launch_type": "single-client"
    }
  ],
  "shortcuts": [
    {
      "name": "Emergency",
      "short_name": "Emergency",
      "description": "Access emergency mode",
      "url": "/Coverly/?tab=emergency",
      "icons": [{ "src": "icon-192-coverly.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Add Policy",
      "short_name": "Add",
      "description": "Add a new insurance policy",
      "url": "/Coverly/?tab=add",
      "icons": [{ "src": "icon-192-coverly.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "prefer_related_applications": false
}
