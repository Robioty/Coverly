{
  "name": "Coverly – Insurance Vault",
  "short_name": "Coverly",
  "version": "1.0.0-beta",
  "description": "Privacy-first, offline insurance vault for emergencies",
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#0a0f1e",
  "theme_color": "#0a0f1e",
  "categories": ["finance", "utilities"],
  "icons": [
    {
      "src": "icon-192-coverly.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512-coverly.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/octet-stream": [".coverly"],
        "application/coverly": [".coverly"]
      },
      "launch_type": "single-client"
    }
  ],
  "screenshots": [
    {
      "src": "screenshots/home.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Coverly Home Screen"
    }
  ],
  "shortcuts": [
    {
      "name": "Emergency",
      "short_name": "Emergency",
      "description": "Access emergency mode",
      "url": "/?tab=emergency",
      "icons": [{ "src": "icon-192-coverly.png", "sizes": "192x192" }]
    },
    {
      "name": "Add Policy",
      "short_name": "Add",
      "description": "Add a new insurance policy",
      "url": "/?tab=add",
      "icons": [{ "src": "icon-192-coverly.png", "sizes": "192x192" }]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false
}
